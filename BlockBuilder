-- Spawn Function
local function spawnVehicle(key)
    local data = VEHICLES[key]
    if not data then return end

    character = getCharacter()
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local origin = hrp.Position + hrp.CFrame.LookVector * CONFIG.SpawnDistance
    local model = Instance.new("Model")
    model.Name = data.Name .. "_Build"
    model.Parent = workspace

    for _, block in ipairs(data.Blocks) do
        local part = Instance.new("Part")
        part.Size = Vector3.new(0.1,0.1,0.1)
        part.Position = origin + block.Offset
        part.Color = block.Color
        part.Anchored = true
        part.Parent = model

        TweenService:Create(part, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = block.Size
        }):Play()
    end
end

